{
  "name": "project-brain",
  "displayName": "Project Brain",
  "description": "在編輯器側欄顯示 Project Brain 的相關知識，讓 AI 記憶觸手可及",
  "version": "1.1.0",
  "publisher": "synthex",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "AI"],
  "keywords": ["ai", "knowledge", "memory", "claude", "synthex"],
  "activationEvents": [
    "workspaceContains:.brain/knowledge_graph.db"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "projectBrain",
          "name": "Project Brain",
          "icon": "icons/brain.svg",
          "contextualTitle": "Project Brain 知識庫"
        }
      ]
    },
    "commands": [
      {
        "command": "projectBrain.refresh",
        "title": "重新整理知識庫",
        "icon": "$(refresh)",
        "category": "Project Brain"
      },
      {
        "command": "projectBrain.search",
        "title": "語義搜尋知識庫",
        "icon": "$(search)",
        "category": "Project Brain"
      },
      {
        "command": "projectBrain.addKnowledge",
        "title": "手動加入知識",
        "icon": "$(add)",
        "category": "Project Brain"
      },
      {
        "command": "projectBrain.showContext",
        "title": "顯示當前任務的 Context",
        "icon": "$(lightbulb)",
        "category": "Project Brain"
      },
      {
        "command": "projectBrain.openGraph",
        "title": "在瀏覽器開啟知識圖譜",
        "icon": "$(graph)",
        "category": "Project Brain"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "projectBrain.refresh",
          "when": "view == projectBrain",
          "group": "navigation"
        },
        {
          "command": "projectBrain.search",
          "when": "view == projectBrain",
          "group": "navigation"
        },
        {
          "command": "projectBrain.addKnowledge",
          "when": "view == projectBrain",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Project Brain",
      "properties": {
        "projectBrain.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "編輯檔案時自動更新知識庫建議"
        },
        "projectBrain.autoRefreshDelay": {
          "type": "number",
          "default": 2000,
          "minimum": 500,
          "maximum": 10000,
          "description": "自動更新延遲（毫秒）"
        },
        "projectBrain.maxResults": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "description": "側欄顯示的最大知識筆數"
        },
        "projectBrain.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python 執行路徑（需要已安裝 SYNTHEX 依賴）"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch":   "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode":    "^1.85.0",
    "@types/node":      "^20.0.0",
    "typescript":       "^5.3.0",
    "@vscode/vsce":     "^2.22.0"
  }
}
