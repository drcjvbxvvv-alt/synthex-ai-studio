{
  "compilerOptions": {
    "module":           "commonjs",
    "target":           "ES2020",
    "outDir":           "./out",
    "rootDir":          "./src",
    "sourceMap":        true,
    "strict":           true,
    "noImplicitAny":    true,
    "esModuleInterop":  true,
    "lib":              ["ES2020"],
    "skipLibCheck":     true
  },
  "exclude": ["node_modules", ".vscode-test"]
}
